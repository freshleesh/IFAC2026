<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="map" description="Map name (folder name in stack_master/maps/)"/>
  <arg name="extract_centerline" default="true" description="Extract centerline from map"/>
  <arg name="optimize" default="false" description="Run IQP+SP trajectory optimization"/>
  <arg name="lattice" default="false" description="Run lattice Dijkstra optimizer"/>
  <arg name="reverse" default="false" description="Reverse centerline direction (true=CW, default=CCW)"/>
  <arg name="output_csv" default="centerline.csv" description="Output CSV filename"/>
  <arg name="lat_samples" default="11" description="Lattice lateral sample count M (odd recommended)"/>
  <arg name="safety_width_lattice" default="0.8" description="Lattice safety clearance [m]"/>

  <!-- Centerline Extractor Node -->
  <node pkg="global_planner" exec="centerline_extractor" name="centerline_extractor" output="screen"
        if="$(var extract_centerline)">
    <param name="map_name" value="$(var map)"/>
    <param name="reverse" value="$(var reverse)"/>
    <param name="output_csv" value="$(var output_csv)"/>
  </node>

  <!-- Trajectory Optimizer Node (IQP + SP) -->
  <node pkg="global_planner" exec="trajectory_optimizer" name="trajectory_optimizer" output="screen"
        if="$(var optimize)">
    <param name="map_name" value="$(var map)"/>
    <param name="input_csv" value="$(var output_csv)"/>
  </node>

  <!-- Lattice Optimizer Node (global min-time via Dijkstra) -->
  <node pkg="global_planner" exec="lattice_optimizer" name="lattice_optimizer" output="screen"
        if="$(var lattice)">
    <param name="map_name" value="$(var map)"/>
    <param name="num_lat_samples" value="$(var lat_samples)"/>
    <param name="safety_width" value="$(var safety_width_lattice)"/>
  </node>

</launch>
